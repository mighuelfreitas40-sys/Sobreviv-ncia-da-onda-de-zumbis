-- Variáveis
local killAuraActive = false
local freeCamActive = false
local safePlayerActive = false

-- ========== KILL AURA ==========
local function KillAuraFunction()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local LocalPlayer = Players.LocalPlayer
    
    -- Procurar o remote
    local FireWeapon = nil
    local Shared = ReplicatedStorage:FindFirstChild("Shared")
    if Shared then
        local Events = Shared:FindFirstChild("Events")
        if Events then
            FireWeapon = Events:FindFirstChild("FireWeapon")
        end
    end
    
    if not FireWeapon then
        warn("Remote FireWeapon não encontrado")
        return
    end
    
    while killAuraActive do
        task.wait(0.2)
        
        local character = LocalPlayer.Character
        if not character then continue end
        
        local revolver = character:FindFirstChild("Revolver")
        if not revolver then continue end
        
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then continue end
        
        -- Buscar alvos
        local alvos = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Humanoid") and obj.Parent ~= character and obj.Health > 0 then
                local targetRoot = obj.Parent:FindFirstChild("HumanoidRootPart")
                if targetRoot then
                    local distancia = (rootPart.Position - targetRoot.Position).Magnitude
                    if distancia <= 1000 then
                        table.insert(alvos, obj.Parent)
                    end
                end
            end
        end
        
        -- Atacar alvos
        for _, alvo in ipairs(alvos) do
            local targetRoot = alvo:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                for i = 1, 20 do
                    local args = {
                        revolver,
                        revolver.Handle.Position,
                        targetRoot.Position,
                        targetRoot,
                        Vector3.yAxis,
                        0
                    }
                    pcall(function()
                        FireWeapon:FireServer(unpack(args))
                    end)
                end
            end
        end
    end
end

OpTab:AddToggle({
    Name = "Kill Aura",
    Default = false,
    Callback = function(Value)
        killAuraActive = Value
        if Value then
            task.spawn(KillAuraFunction)
        end
    end
})

-- ========== FREE CAM ==========
local freeCamPart = nil
local freeCamBodyVel = nil
local freeCamMoveDir = Vector3.new(0, 0, 0)
local freeCamInputBegan = nil
local freeCamInputEnded = nil
local freeCamRender = nil
local freeCamCameraCFrame = nil

local function FreeCamUpdate()
    if not freeCamActive then return end
    
    local camera = workspace.CurrentCamera
    local speed = 50
    
    local look = camera.CFrame.LookVector
    local right = camera.CFrame.RightVector
    local up = camera.CFrame.UpVector
    
    local move = (look * freeCamMoveDir.Z) + (right * freeCamMoveDir.X) + (up * freeCamMoveDir.Y)
    
    if move.Magnitude > 0 then
        move = move.Unit * speed
    end
    
    if freeCamBodyVel then
        freeCamBodyVel.Velocity = move
    end
end

local function StartFreeCam()
    if freeCamActive then return end
    
    local player = game.Players.LocalPlayer
    local camera = workspace.CurrentCamera
    local character = player.Character
    
    if not character then return end
    
    -- Salvar posição da câmera
    freeCamCameraCFrame = camera.CFrame
    
    -- Criar part circular
    freeCamPart = Instance.new("Part")
    freeCamPart.Size = Vector3.new(1, 1, 1)
    freeCamPart.Shape = Enum.PartType.Ball
    freeCamPart.Transparency = 0.5
    freeCamPart.Material = Enum.Material.Neon
    freeCamPart.BrickColor = BrickColor.new("Bright blue")
    freeCamPart.Anchored = false
    freeCamPart.CanCollide = false
    freeCamPart.Position = camera.CFrame.Position
    freeCamPart.Parent = workspace
    
    -- BodyVelocity para movimento
    freeCamBodyVel = Instance.new("BodyVelocity")
    freeCamBodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    freeCamBodyVel.Velocity = Vector3.new(0, 0, 0)
    freeCamBodyVel.Parent = freeCamPart
    
    -- Inputs
    local UIS = game:GetService("UserInputService")
    
    freeCamInputBegan = UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or not freeCamActive then return end
        
        local key = input.KeyCode
        if key == Enum.KeyCode.W then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(0, 0, 1)
        elseif key == Enum.KeyCode.S then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(0, 0, -1)
        elseif key == Enum.KeyCode.A then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(-1, 0, 0)
        elseif key == Enum.KeyCode.D then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(1, 0, 0)
        elseif key == Enum.KeyCode.Space then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(0, 1, 0)
        elseif key == Enum.KeyCode.LeftControl then
            freeCamMoveDir = freeCamMoveDir + Vector3.new(0, -1, 0)
        end
        FreeCamUpdate()
    end)
    
    freeCamInputEnded = UIS.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed or not freeCamActive then return end
        
        local key = input.KeyCode
        if key == Enum.KeyCode.W then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(0, 0, 1)
        elseif key == Enum.KeyCode.S then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(0, 0, -1)
        elseif key == Enum.KeyCode.A then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(-1, 0, 0)
        elseif key == Enum.KeyCode.D then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(1, 0, 0)
        elseif key == Enum.KeyCode.Space then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(0, 1, 0)
        elseif key == Enum.KeyCode.LeftControl then
            freeCamMoveDir = freeCamMoveDir - Vector3.new(0, -1, 0)
        end
        FreeCamUpdate()
    end)
    
    -- Render step para seguir a part
    freeCamRender = game:GetService("RunService").RenderStepped:Connect(function()
        if freeCamActive and freeCamPart then
            local cam = workspace.CurrentCamera
            cam.CFrame = CFrame.new(freeCamPart.Position, freeCamPart.Position + cam.CFrame.LookVector)
        end
    end)
    
    -- Desabilitar personagem
    if character:FindFirstChild("Humanoid") then
        character.Humanoid.PlatformStand = true
    end
    
    -- Esconder personagem
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
        end
    end
    
    freeCamActive = true
end

local function StopFreeCam()
    if not freeCamActive then return end
    
    -- Desconectar eventos
    if freeCamInputBegan then
        freeCamInputBegan:Disconnect()
        freeCamInputBegan = nil
    end
    
    if freeCamInputEnded then
        freeCamInputEnded:Disconnect()
        freeCamInputEnded = nil
    end
    
    if freeCamRender then
        freeCamRender:Disconnect()
        freeCamRender = nil
    end
    
    -- Destruir part
    if freeCamPart then
        freeCamPart:Destroy()
        freeCamPart = nil
    end
    
    if freeCamBodyVel then
        freeCamBodyVel:Destroy()
        freeCamBodyVel = nil
    end
    
    -- Restaurar câmera
    if freeCamCameraCFrame then
        workspace.CurrentCamera.CFrame = freeCamCameraCFrame
    end
    
    -- Restaurar personagem
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if character then
        if character:FindFirstChild("Humanoid") then
            character.Humanoid.PlatformStand = false
        end
        
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0
            end
        end
    end
    
    freeCamMoveDir = Vector3.new(0, 0, 0)
    freeCamActive = false
end

MainTab:AddToggle({
    Name = "Free Cam",
    Default = false,
    Callback = function(Value)
        if Value then
            StartFreeCam()
        else
            StopFreeCam()
        end
    end
})

-- ========== SAFE PLAYER ==========
local safeStartPosition = nil
local safePart = nil
local safeBodyVel = nil

local function StartSafePlayer()
    if safePlayerActive then return end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    -- Salvar posição inicial
    safeStartPosition = rootPart.Position
    
    -- Teleportar para cima
    local newPos = safeStartPosition + Vector3.new(0, 200, 0)
    rootPart.CFrame = CFrame.new(newPos)
    
    -- Criar part circular
    safePart = Instance.new("Part")
    safePart.Size = Vector3.new(1, 1, 1)
    safePart.Shape = Enum.PartType.Ball
    safePart.Transparency = 0.5
    safePart.Material = Enum.Material.Neon
    safePart.BrickColor = BrickColor.new("Bright green")
    safePart.Anchored = false
    safePart.CanCollide = false
    safePart.Position = newPos
    safePart.Parent = character
    
    -- BodyVelocity para flutuar
    safeBodyVel = Instance.new("BodyVelocity")
    safeBodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    safeBodyVel.Velocity = Vector3.new(0, 0, 0)
    safeBodyVel.Parent = safePart
    
    -- Desabilitar movimento
    if character:FindFirstChild("Humanoid") then
        character.Humanoid.PlatformStand = true
    end
    
    safePlayerActive = true
end

local function StopSafePlayer()
    if not safePlayerActive then return end
    
    local player = game.Players.LocalPlayer
    local character = player.Character
    
    if character and safeStartPosition then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.CFrame = CFrame.new(safeStartPosition)
        end
        
        if safePart then
            safePart:Destroy()
            safePart = nil
        end
        
        if safeBodyVel then
            safeBodyVel:Destroy()
            safeBodyVel = nil
        end
        
        if character:FindFirstChild("Humanoid") then
            character.Humanoid.PlatformStand = false
        end
    end
    
    safePlayerActive = false
    safeStartPosition = nil
end

MainTab:AddToggle({
    Name = "Safe Player",
    Default = false,
    Callback = function(Value)
        if Value then
            StartSafePlayer()
        else
            StopSafePlayer()
        end
    end
})

-- Limpar ao morrer
game.Players.LocalPlayer.CharacterAdded:Connect(function()
    if freeCamActive then
        StopFreeCam()
    end
    if safePlayerActive then
        StopSafePlayer()
    end
end)

